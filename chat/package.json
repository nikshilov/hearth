{
  "name": "hearth-chat",
  "version": "0.1.0",
  "private": true,
  "description": "Hearth — emotional chat UI for Pulse-backed conversations. Vanilla TypeScript + custom elements.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=esm --target=es2022 --minify --sourcemap --loader:.md=text --outfile=dist/app.js",
    "dev": "node ./dev-server.mjs",
    "watch": "esbuild src/main.ts --bundle --format=esm --target=es2022 --sourcemap --watch --loader:.md=text --outfile=dist/app.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
